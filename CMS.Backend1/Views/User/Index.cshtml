@model IEnumerable<CMS.Data.Entities.User>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-dark fw-bold text-uppercase">👤 QUẢN LÝ THÀNH VIÊN</h2>
        <button class="btn btn-success btn-sm">+ Thêm thành viên mới</button>
    </div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle border mb-0">
            <thead class="table-dark">
                <tr>
                    <th style="width: 80px;" class="text-center">ID</th>
                    <th>Tên Đăng Nhập</th>
                    <th>Họ Và Tên</th>
                    <th>Quyền Hạn</th>
                    <th style="width: 150px;" class="text-center">Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="text-center fw-bold">@user.Id</td>
                        <td><span class="badge bg-light text-dark border">@user.Username</span></td>
                        <td><strong>@user.FullName</strong></td>
                        <td>
                            @if (user.Role == "Admin")
                            {
                                <span class="badge bg-danger">@user.Role</span>
                            }
                            else if (user.Role == "Editor")
                            {
                                <span class="badge bg-warning text-dark">@user.Role</span>
                            }
                            else if (user.Role == "Moderator")
                            {
                                <span class="badge bg-primary">@user.Role</span>
                            }
                            else
                            {
                                <span class="badge bg-info text-dark">@user.Role</span>
                            }
                        </td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-outline-warning">Sửa</button>
                            <button class="btn btn-sm btn-outline-danger">Xóa</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>