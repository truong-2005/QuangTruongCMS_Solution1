@model IEnumerable<CMS.Data.Entities.OrderDetail>

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
    var order = ViewBag.Order as CMS.Data.Entities.Order;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a href="/Orders" class="btn btn-outline-secondary btn-sm mb-2">
                <i class="bi bi-arrow-left"></i> Quay lại danh sách đơn
            </a>
            <h3 class="text-dark fw-bold text-uppercase mb-0">🔍 CHI TIẾT ĐƠN HÀNG #@order?.Id</h3>
            <small class="text-muted">Ngày đặt: @order?.OrderDate.ToString("dd/MM/yyyy HH:mm")</small>
        </div>
        <div class="text-end">
            <span class="d-block text-muted small">Khách hàng</span>
            <span class="fw-bold text-primary fs-5">@(order?.Customer != null ? order.Customer.FullName : "Khách hàng vãng lai")</span>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-primary text-uppercase" style="font-size: 0.85rem;">
                        <tr>
                            <th class="ps-4 py-3" style="width: 15%;">Mã CTĐH</th>
                            <th style="width: 40%;">Tên sản phẩm</th>
                            <th style="width: 15%;" class="text-end">Đơn giá</th>
                            <th style="width: 15%;" class="text-center">Số lượng</th>
                            <th style="width: 15%;" class="text-end pe-4">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            decimal tongTienDonHang = 0;
                            foreach (var item in Model)
                            {
                                var thanhTien = (item.UnitPrice * item.Quantity);
                                tongTienDonHang += thanhTien;

                                <tr>
                                    <td class="ps-4 fw-bold text-secondary">#@item.Id</td>
                                    <td>
                                        <div class="fw-semibold text-dark">
                                            @(item.Product != null ? item.Product.Name : "Sản phẩm #" + item.ProductId)
                                        </div>
                                        <small class="text-muted">Mã số SP: @item.ProductId</small>
                                    </td>
                                    <td class="text-end fw-medium text-secondary">@item.UnitPrice.ToString("N0") đ</td>
                                    <td class="text-center fw-bold">@item.Quantity</td>
                                    <td class="text-end pe-4 fw-bold text-danger">@thanhTien.ToString("N0") đ</td>
                                </tr>
                            }
                            <tr class="table-light">
                                <td colspan="4" class="text-end fw-bold py-3">Tổng giá trị đơn hàng:</td>
                                <td class="text-end pe-4 fw-bolder text-danger fs-5 py-3">@tongTienDonHang.ToString("N0") đ</td>
                            </tr>
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-5">
                                    <i class="bi bi-basket3 fs-2 d-block mb-2"></i>
                                    Không tìm thấy sản phẩm nào trong chi tiết đơn hàng này.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">