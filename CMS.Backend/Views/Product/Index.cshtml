@model IEnumerable<CMS.Data.Entities.Product>

@{
    ViewData["Title"] = "Danh sách sản phẩm";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-danger fw-bold text-uppercase">🛍️ Danh sách sản phẩm mới nhất</h2>
        <a href="/Product/Create" class="btn btn-primary shadow-sm">➕ Thêm sản phẩm mới</a>
    </div>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm border-0 bg-light">
                        <img src="@item.ImageUrl" class="card-img-top" alt="Product Image" style="height: 180px; object-fit: cover;">

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title text-primary fw-bold">@item.Name</h5>

                            <p class="card-text text-muted flex-grow-1" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                                @item.Description
                            </p>

                            <div class="mt-auto">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="text-danger fw-bold">💰 Giá: @item.Price.ToString("#,##0") VNĐ</span>
                                    <span class="text-secondary small">📦 Kho: @item.StockQuantity</span>
                                </div>

                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <span class="badge bg-secondary">Danh mục Mã: @item.CategoryProductId</span>
                                    <div class="btn-group btn-group-sm">
                                        <a href="/Product/Edit/@item.Id" class="btn btn-outline-warning">Sửa</a>
                                        <a href="/Product/Details/@item.Id" class="btn btn-outline-info">Chi tiết</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <p class="text-muted fs-5">Hiện chưa có sản phẩm nào trong cơ sở dữ liệu.</p>
            </div>
        }
    </div>
</div>